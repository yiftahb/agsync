{
  "name": "agsync-cli",
  "version": "1.5.2",
  "description": "Git-native CLI to sync skills, MCP tools, and policies across AI coding clients",
  "type": "module",
  "bin": {
    "agsync": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "claude",
    "cursor",
    "codex",
    "sync"
  ],
  "author": "Yiftah Barouch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yiftahb/agsync.git"
  },
  "homepage": "https://github.com/yiftahb/agsync#readme",
  "bugs": {
    "url": "https://github.com/yiftahb/agsync/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.2",
    "smol-toml": "^1.6.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "eslint": "^9.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  },
  "packageManager": "pnpm@9.15.5+sha1.cb1f6372ef64e2ba352f2f46325adead1c99ff8f"
}
